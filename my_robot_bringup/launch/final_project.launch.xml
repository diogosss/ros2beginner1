<launch>
    <node pkg="turtlesim" exec="turtlesim_node"  />

    <executable cmd="ros2 turtlesim call /kill turtlesim/srv/Kill '{name: 'turtle1'}'" output="screen"/>

    <executable cmd="ros2 run rclcpp_components component_container_mt" name="turtle_container"/>

    <node pkg="rclcpp_components" exec="component_container_mt" name="turtle_container"/>

    <executable cmd="ros2 component load /turtle_container final_project_cpp final_project::TurtleController 
                    -r __node:=turtle_controller_1 
                    -p turtle_name:=feg" output="screen"/>

    <node pkg="lifecycle_py" exec="lifecycle_node_manager">
        <param name="managed_node_name" value="turtle_controller_1"></param>
    </node>
</launch>


