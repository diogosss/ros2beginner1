<launch>

    <set_env name="TURTLEBOT3_MODEL" value="waffle"/>

    <include file="$(find-pkg-share turtlebot3_gazebo)/launch/empty_world.launch.py"></include>

    <executable cmd="ros2 run rclcpp_components component_container_mt" name="turtle_container"/>

    <node pkg="rclcpp_components" exec="component_container_mt" name="turtle_container"/>

    <executable cmd="ros2 component load /turtle_container final_project_cpp final_project::TurtleBot3Controller 
                    -r __node:=turtle_controller_1 " output="screen"/>

    <node pkg="lifecycle_py" exec="lifecycle_node_manager">
        <param name="managed_node_name" value="turtle_controller_1"></param>
    </node>
</launch>


